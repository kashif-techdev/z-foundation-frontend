# Site
NEXT_PUBLIC_SITE_URL=https://zifoundation.com

# Hostinger SMTP (server-only — never NEXT_PUBLIC_*)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@zifoundation.com
SMTP_PASS=your-mailbox-password-here

# Optional: override From header (defaults to SMTP_USER)
# SMTP_FROM=info@zifoundation.com

# Optional: display name in email header
MAIL_SITE_NAME=Z-Foundation

# Inboxes (defaults match zifoundation.com if unset)
# MAIL_TO_INFO=info@zifoundation.com
# MAIL_TO_DONATE=donate@zifoundation.com
# MAIL_TO_VOLUNTEER=volunteer@zifoundation.com
# MAIL_TO_SUPPORT=support@zifoundation.com
